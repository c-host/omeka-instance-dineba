# Pinned stack — adjust for your machine only
OMEKA_S_VERSION=4.2.0
PHP_VERSION=8.2
APPLICATION_ENV=development

# Must differ per instance (keeps separate Docker volumes)
COMPOSE_PROJECT_NAME=dineba-omeka-s

# MariaDB (matches compose defaults; data persists in Docker volume)
MYSQL_ROOT_PASSWORD=omeka_admin
MYSQL_DATABASE=omeka
MYSQL_USER=omeka
MYSQL_PASSWORD=omeka
MYSQL_HOST=db

# Mailpit: SMTP inside Docker network
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_CONNECTION_TYPE=

# Stock modules from https://omeka.org/add-ons/json/s_module.json
# Internationalisation is required for the Freedom theme language switcher.
OMEKA_S_MODULES="Mapping Collecting Common CustomVocab Annotate DataTypeGeometry Cartography CSSEditor CleanUrl Table Log Easyadmin AdvancedResourceTemplate Contribute MetadataBrowse Timeline BlockPlus ShowMore UniversalViewer Mirador BlocksDisposition Guest RoleBasedNavigation Internationalisation https://github.com/c-host/Omeka-S-module-InternetArchiveInboundSync/releases/download/v1.3.0/InternetArchiveInboundSync.zip https://github.com/c-host/Omeka-S-module-InternetArchiveOutboundSync/releases/download/v1.0.0/InternetArchiveOutboundSync.zip https://github.com/c-host/Omeka-S-module-ContributeEnhancements/releases/download/v1.3.3/ContributeEnhancements.zip"

# Custom Freedom theme fork (top-level folder in zip must be `freedom`)
OMEKA_S_THEMES="default https://github.com/c-host/freedom/releases/download/v1.1.4/freedom.zip"

OMEKA_S_ALLOW_EASY_ADMIN=1

# Existing install — do not set to 1 on a live database
OMEKA_S_INSTALL_CORE=0
OMEKA_S_INSTALL_MODULES=0

OMEKA_S_TITLE="Omeka S Dineba"
OMEKA_S_TIME_ZONE="UTC"
OMEKA_S_LOCALE="en_US"
OMEKA_S_ADMIN_NAME="admin"
OMEKA_S_ADMIN_EMAIL="admin@example.com"
OMEKA_S_ADMIN_PASSWORD="change-me"

# Optional: route Collecting uploads to IA test_collection during dev
# IA_PUBLISH_TEST_COLLECTION=test_collection
